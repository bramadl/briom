{
	"compilerOptions": {
		"target": "ES2017",
		"lib": ["dom", "dom.iterable", "esnext"],
		"allowJs": true,
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "react-jsx",
		"incremental": true,
		"plugins": [{ "name": "next" }],
		"paths": {
			// Back End: Core
			"@briom/core/app": ["./src/core/application/index.ts"],
			"@briom/core/domain": ["./src/core/domain/index.ts"],
			"@briom/core/infra/auth": ["./src/core/infrastructure/auth/index.ts"],
			"@briom/core/infra/adapters": [
				"./src/core/infrastructure/adapters/index.ts"
			],
			"@briom/core/infra/database": [
				"./src/core/infrastructure/database/index.ts"
			],

			// Core Library: Drimion
			"@drimion": ["./src/libs/drimion"],
			"@drimion/*": ["./src/libs/drimion/*"],

			// Front End: Scoped Modules
			"@briom/auth/*": ["./src/app/auth/*"],
			"@briom/moderator/*": ["./src/features/moderator/*"],
			"@briom/room/*": ["./src/features/room/*"],

			// Front End: Generic
			"@briom/animated/*": ["./src/components/animated/*"],
			"@briom/components/*": ["./src/components/*"],
			"@briom/ui/*": ["./src/components/ui/*"],
			"@briom/hooks/*": ["./src/hooks/*"],

			// Back End: Providers
			"@briom/drizzle/*": ["./src/core/infrastructure/.providers/drizzle/*"],
			"@briom/inngest/*": ["./src/core/infrastructure/.providers/inngest/*"],
			"@briom/posthog/*": ["./src/core/infrastructure/.providers/posthog/*"],
			"@briom/supabase/*": ["./src/core/infrastructure/.providers/supabase/*"],
			"@briom/openrouter/*": [
				"./src/core/infrastructure/.providers/openrouter/*"
			],

			// Generic: Libraries (mostly FE needs)
			"@briom/libs/*": ["./src/libs/*"],

			// Shadcn: Required by them
			"@briom/utils": ["./src/libs/utils.ts"],
			"@briom/*": ["./src/*"],

			// Main: Briom Facade
			"@briom": ["./src/core/.container/index.ts"]
		}
	},
	"include": [
		"next-env.d.ts",
		"**/*.ts",
		"**/*.tsx",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts",
		"**/*.mts",

		// A special directory containing (.)-prefix
		"src/core/infrastructure/.providers/**/*.ts",
		"src/core/.container/**/*.ts"
	],
	"exclude": ["node_modules"]
}
