{
	"compilerOptions": {
		"target": "ES2017",
		"lib": ["dom", "dom.iterable", "esnext"],
		"allowJs": true,
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "react-jsx",
		"incremental": true,
		"plugins": [
			{
				"name": "next"
			}
		],
		"paths": {
			// Next.js
			"@briom/animated/*": ["./src/components/animated/*"],
			"@briom/components/*": ["./src/components/*"],
			"@briom/ui/*": ["./src/components/ui/*"],
			"@briom/hooks/*": ["./src/hooks/*"],

			// Submodule FE
			"@briom/auth/*": ["./src/app/(auth)/*"],
			"@briom/rooms/*": ["./src/app/(rooms)/*"],

			// Client
			"@briom": ["./src/container"],
			"@briom/client": ["./src/libs/briom/client.ts"],

			// Core
			"@briom/app": ["./src/core/application"],
			"@briom/app/*": ["./src/core/application/*"],
			"@briom/domain": ["./src/core/domain"],
			"@briom/domain/*": ["./src/core/domain/*"],
			"@briom/shared": ["./src/core/shared"],
			"@briom/shared/*": ["./src/core/shared/*"],

			// Libs
			"@briom/libs/*": ["./src/libs/*"],
			"@briom/utils": ["./src/libs/utils.ts"],
			"@briom/drimion": ["./src/libs/drimion"],
			"@briom/drimion/*": ["./src/libs/drimion/*"],

			// Providers
			"@briom/supabase": ["./src/libs/providers/supabase"],
			"@briom/supabase/*": ["./src/libs/providers/supabase/*"],
			"@briom/drizzle": ["./src/libs/providers/drizzle"],
			"@briom/drizzle/*": ["./src/libs/providers/drizzle/*"],
			"@briom/open-router": ["./src/libs/providers/open-router"],
			"@briom/open-router/*": ["./src/libs/providers/open-router/*"],

			// Shadcn
			"@briom/*": ["./src/*"]
		}
	},
	"include": [
		"next-env.d.ts",
		"**/*.ts",
		"**/*.tsx",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts",
		"**/*.mts"
	],
	"exclude": ["node_modules"]
}
