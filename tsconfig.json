{
	"compilerOptions": {
		"target": "ES2017",
		"lib": ["dom", "dom.iterable", "esnext"],
		"allowJs": true,
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "react-jsx",
		"incremental": true,
		"plugins": [
			{
				"name": "next"
			}
		],
		"paths": {
			// Core
			"@briom/app": ["./src/core/application"],
			"@briom/app/*": ["./src/core/application/*"],
			"@briom/domain": ["./src/core/domain"],
			"@briom/domain/*": ["./src/core/domain/*"],
			"@briom/shared": ["./src/core/shared"],
			"@briom/shared/*": ["./src/core/shared/*"],

			// Libs
			"@briom/drimion": ["./src/libs/drimion"],
			"@briom/drimion/*": ["./src/libs/drimion/*"],

			// Providers
			"@briom/drizzle": ["./src/libs/providers/drizzle"],
			"@briom/drizzle/*": ["./src/libs/providers/drizzle/*"],
			"@briom/open-router": ["./src/libs/providers/open-router"],
			"@briom/open-router/*": ["./src/libs/providers/open-router/*"],

			// Container
			"@briom/container": ["./src/container"]
		}
	},
	"include": [
		"next-env.d.ts",
		"**/*.ts",
		"**/*.tsx",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts",
		"**/*.mts"
	],
	"exclude": ["node_modules"]
}
